{
  "expo": {
    "name": "Quicksave",
    "slug": "quicksave",
    "jsEngine": "hermes",
    "version": "1.0.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "icon": "./assets/main-logo.png",
    "scheme": "quicksave",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/main-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF",
      "dark": {
        "image": "./assets/main-logo.png",
        "backgroundColor": "#121212"
      }
    },
    "ios": {
      "icon": "./assets/main-logo.png",
      "bundleIdentifier": "com.clotidestark25.quicksave",
      "infoPlist": {
        "NSFaceIDUsageDescription": "QuickSave uses Face ID to securely unlock your vault and authorize transactions.",
        "NSCameraUsageDescription": "QuickSave needs camera access to scan Group Invite QR codes.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/main-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "versionCode": 1,
      "package": "com.clotidestark25.quicksave"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/icon-app.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Quicksave needs access to your camera so you can scan QR codes to join savings groups."
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-sqlite",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "Quicksave"
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bedb6fe3-0bfe-41cf-afd4-472dc3759de7"
      }
    }
  }
}
