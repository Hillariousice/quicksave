generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url and directUrl are removed here for Prisma 7!
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum GroupStatus {
  PENDING
  ACTIVE
  PAUSED  
  COMPLETED
  CANCELLED
}

enum MemberRole {
  ADMIN
  MEMBER
}

enum MemberStatus {
  PENDING
  ACTIVE
  REMOVED
}

enum ContributionStatus {
  PENDING
  CONFIRMED
  MISSED
  LATE
}

enum TransactionType {
  CONTRIBUTION
  WITHDRAWAL
  PAYOUT
  REFUND
  FEE
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

enum NotificationType {
  CONTRIBUTION_DUE
  CONTRIBUTION_CONFIRMED
  PAYOUT_SCHEDULED
  PAYOUT_SENT
  GROUP_INVITE
  GROUP_UPDATE
  SYSTEM
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}



model User {
  id            String      @id @default(uuid())
  email         String      @unique
  phone         String      @unique
  firstName     String
  lastName      String
  passwordHash  String
  pin           String?     // hashed 4-digit transaction PIN
  avatar        String?
  status        UserStatus  @default(ACTIVE)
  refreshToken  String?
  isVerified    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  groupsCreated  Group[]         @relation("GroupCreator")
  memberships    GroupMember[]
  contributions  Contribution[]
  wallet         Wallet?
  notifications  Notification[]
  rotationSlots  RotationSlot[]
  activityLogs   ActivityLog[]

  @@map("users")
}

model Group {
  id          String        @id @default(uuid())
  name        String 
  description       String?       
  contributionAmount Float   
  frequency   Frequency     @default(MONTHLY)
 
  startDate         DateTime?
  payoutDate        DateTime?
  nextPayoutDate    DateTime?

  inviteCode        String        @unique 
  maxCapacity       Int           @default(10)
  currentMembers    Int           @default(0)     
  totalContributions Float   @default(0)
  cycleCount         Int           @default(0)      
  cycleDuration      Int           @default(1)
  status            GroupStatus   @default(PENDING)
  creatorId         String

  creator           User          @relation("GroupCreator", fields: [creatorId], references: [id])
  members           GroupMember[]
  wallet            Wallet?
  contributions     Contribution[]
  rotationSlots     RotationSlot[] 
  activityLogs ActivityLog[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt


}

model GroupMember {
  id        String       @id @default(uuid())
  userId    String
  groupId   String
  role      MemberRole   @default(MEMBER)
  position    Int?              // payout order position
  joinedAt    DateTime     @default(now()) 
  status    MemberStatus @default(PENDING)
  user      User         @relation(fields: [userId], references: [id])
  group     Group        @relation(fields: [groupId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  
  @@unique([userId, groupId])
}

model Contribution {
  id        String             @id @default(uuid())
  userId    String
  groupId   String
  paidAt    DateTime?
  amount    Float 
  status    ContributionStatus @default(PENDING)
  user      User?              @relation(fields: [userId], references: [id])
  group     Group?             @relation(fields: [groupId], references: [id])
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Wallet {
  id        String   @id @default(uuid())
  balance   Float    @default(0)  
  currency    String    @default("NGN")
  userId    String?   @unique
  groupId   String?  @unique 
  user      User?     @relation(fields: [userId], references: [id])
  group     Group?   @relation(fields: [groupId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  user      User             @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())
}

model RotationSlot {
  id                 String       @id @default(uuid())
  position           Int          
  expectedPayoutDate DateTime     
  status             PayoutStatus @default(PENDING)
  userId             String
  groupId            String
  user               User         @relation(fields: [userId], references: [id])
  group              Group        @relation(fields: [groupId], references: [id])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([groupId, position])
  @@unique([groupId, userId])   
}

model ActivityLog {
  id        String   @id @default(uuid())
  groupId   String
  userId    String?  // Optional: System events won't have a user
  action    String   // e.g., "JOINED", "CONTRIBUTION", "STATUS_UPDATE"
  message   String   // e.g., "Amara joined the group"
  createdAt DateTime @default(now())

  group     Group    @relation(fields: [groupId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}