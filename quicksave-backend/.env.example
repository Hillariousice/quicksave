# Server
NODE_ENV="development"
PORT="5000"
FRONTEND_URL="http://localhost:8081"

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/ajo_db"
DIRECT_URL="postgresql://user:password@localhost:5432/ajo_db"

# Redis (For Bull Queues & Presence)
REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET="your_super_secret_jwt_string_must_be_32_chars"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="your_super_secret_refresh_token_string_must_be_32_chars"
REFRESH_TOKEN_EXPIRES_IN="30d"

# Paystack (Payments)
PAYSTACK_SECRET_KEY="sk_test_xxxxxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxxxxx"
PAYSTACK_WEBHOOK_SECRET="your_webhook_secret"

# Notifications (Optional)
FCM_SERVER_KEY=""


TWILIO_ACCOUNT_SID="ACxxxxxxxxx..."
TWILIO_AUTH_TOKEN="your_auth_token_here"
TWILIO_PHONE_NUMBER="+1234567890" # Your Twilio number 

EXPO_ACCESS_TOKEN="optional_for_server_sdk"